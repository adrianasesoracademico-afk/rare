<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ecosistema de Experiencia Activa</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }

        .step-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 180px; /* Altura fija para uniformidad */
        }

        .node-connector {
            height: 2px;
            background: linear-gradient(90deg, #e2e8f0 0%, #cbd5e1 100%);
            flex-grow: 1;
            align-self: center;
        }

        .outcome-box {
            animation: fadeIn 0.4s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .toggle-dot {
            transition: all 0.3s ease;
        }
    </style>
</head>
<body class="p-4 md:p-8">

    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <header class="mb-12 text-center">
            <h1 class="text-4xl font-bold text-slate-800 mb-2">Ecosistema de Experiencia Activa</h1>
            <p class="text-slate-500 max-w-2xl mx-auto">Sintetiza la secuencia lógica del aprendizaje activo para garantizar coherencia pedagógica.</p>
        </header>

        <!-- Main Sequence Visualization -->
        <div class="bg-white rounded-3xl p-6 md:p-10 shadow-sm border border-slate-100 mb-8">
            <h2 class="text-xl font-semibold text-slate-700 mb-10 flex items-center">
                <i class="fas fa-project-diagram mr-3 text-indigo-500"></i> La Secuencia Lógica
            </h2>
            
            <div class="flex flex-col md:flex-row items-stretch justify-between gap-4">
                <!-- Reto -->
                <div id="card-reto" class="step-card bg-indigo-50 border-2 border-indigo-200 p-6 rounded-2xl w-full md:w-1/4 text-center">
                    <div class="w-12 h-12 bg-indigo-500 text-white rounded-xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-indigo-200">
                        <i class="fas fa-flag-checkered text-xl"></i>
                    </div>
                    <h3 class="font-bold text-indigo-900 mb-2">RETO</h3>
                    <p class="text-xs text-indigo-700 leading-relaxed">El disparador del proceso</p>
                </div>

                <div class="hidden md:block node-connector"></div>

                <!-- Acción -->
                <div id="card-accion" class="step-card bg-emerald-50 border-2 border-emerald-200 p-6 rounded-2xl w-full md:w-1/4 text-center">
                    <div class="w-12 h-12 bg-emerald-500 text-white rounded-xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-emerald-200">
                        <i class="fas fa-bolt text-xl"></i>
                    </div>
                    <h3 class="font-bold text-emerald-900 mb-2">ACCIÓN</h3>
                    <p class="text-xs text-emerald-700 leading-relaxed">La puesta en práctica</p>
                </div>

                <div class="hidden md:block node-connector"></div>

                <!-- Reflexión -->
                <div id="card-reflexion" class="step-card bg-amber-50 border-2 border-amber-200 p-6 rounded-2xl w-full md:w-1/4 text-center">
                    <div class="w-12 h-12 bg-amber-500 text-white rounded-xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-amber-200">
                        <i class="fas fa-brain text-xl"></i>
                    </div>
                    <h3 class="font-bold text-amber-900 mb-2">REFLEXIÓN</h3>
                    <p class="text-xs text-amber-700 leading-relaxed">El procesamiento crítico</p>
                </div>

                <div class="hidden md:block node-connector"></div>

                <!-- Evidencia -->
                <div id="card-evidencia" class="step-card bg-blue-50 border-2 border-blue-200 p-6 rounded-2xl w-full md:w-1/4 text-center">
                    <div class="w-12 h-12 bg-blue-500 text-white rounded-xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-blue-200">
                        <i class="fas fa-file-signature text-xl"></i>
                    </div>
                    <h3 class="font-bold text-blue-900 mb-2">EVIDENCIA</h3>
                    <p class="text-xs text-blue-700 leading-relaxed">La validación real</p>
                </div>
            </div>
        </div>

        <!-- Simulator Section -->
        <div class="max-w-3xl mx-auto">
            <div class="bg-white rounded-3xl p-8 shadow-sm border border-slate-100">
                <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
                    <div>
                        <h2 class="text-xl font-semibold text-slate-700">Simulador de Vacíos</h2>
                        <p class="text-sm text-slate-500 italic">Desactiva un elemento para ver la consecuencia pedagógica.</p>
                    </div>
                    <button onclick="resetSim()" class="text-xs font-bold text-indigo-600 hover:text-indigo-800 uppercase tracking-wider">
                        <i class="fas fa-sync-alt mr-1"></i> Reiniciar
                    </button>
                </div>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div onclick="toggleStep('reto')" id="btn-reto" class="flex items-center justify-between p-4 rounded-xl border-2 border-indigo-100 cursor-pointer bg-white hover:bg-indigo-50 transition-all select-none">
                        <span class="font-medium text-slate-700">¿Incluir Reto?</span>
                        <div id="toggle-bg-reto" class="w-10 h-6 bg-indigo-500 rounded-full flex items-center px-1 transition-all">
                            <div id="dot-reto" class="toggle-dot w-4 h-4 bg-white rounded-full ml-auto shadow-sm"></div>
                        </div>
                    </div>
                    <div onclick="toggleStep('accion')" id="btn-accion" class="flex items-center justify-between p-4 rounded-xl border-2 border-emerald-100 cursor-pointer bg-white hover:bg-emerald-50 transition-all select-none">
                        <span class="font-medium text-slate-700">¿Incluir Acción?</span>
                        <div id="toggle-bg-accion" class="w-10 h-6 bg-emerald-500 rounded-full flex items-center px-1 transition-all">
                            <div id="dot-accion" class="toggle-dot w-4 h-4 bg-white rounded-full ml-auto shadow-sm"></div>
                        </div>
                    </div>
                    <div onclick="toggleStep('reflexion')" id="btn-reflexion" class="flex items-center justify-between p-4 rounded-xl border-2 border-amber-100 cursor-pointer bg-white hover:bg-amber-50 transition-all select-none">
                        <span class="font-medium text-slate-700">¿Incluir Reflexión?</span>
                        <div id="toggle-bg-reflexion" class="w-10 h-6 bg-amber-500 rounded-full flex items-center px-1 transition-all">
                            <div id="dot-reflexion" class="toggle-dot w-4 h-4 bg-white rounded-full ml-auto shadow-sm"></div>
                        </div>
                    </div>
                    <div onclick="toggleStep('evidencia')" id="btn-evidencia" class="flex items-center justify-between p-4 rounded-xl border-2 border-blue-100 cursor-pointer bg-white hover:bg-blue-50 transition-all select-none">
                        <span class="font-medium text-slate-700">¿Incluir Evidencia?</span>
                        <div id="toggle-bg-evidencia" class="w-10 h-6 bg-blue-500 rounded-full flex items-center px-1 transition-all">
                            <div id="dot-evidencia" class="toggle-dot w-4 h-4 bg-white rounded-full ml-auto shadow-sm"></div>
                        </div>
                    </div>
                </div>

                <div id="consequence-container" class="mt-8 p-6 rounded-2xl bg-slate-50 border border-slate-200 min-h-[120px] flex items-center justify-center text-center">
                    <p id="consequence-text" class="text-slate-600 font-medium italic">
                        Selecciona un elemento para evaluar el impacto.
                    </p>
                </div>
            </div>
        </div>

        <footer class="mt-12 text-center text-slate-400 text-sm">
            <p>Estructura R.A.R.E. (Reto, Acción, Reflexión, Evidencia)</p>
        </footer>
    </div>

    <script>
        const state = {
            reto: true,
            accion: true,
            reflexion: true,
            evidencia: true
        };

        const consequences = {
            reto: "⚠️ <strong>Sin RETO</strong>: Hay actividad sin propósito. Los estudiantes están ocupados pero no comprometidos.",
            accion: "⚠️ <strong>Sin ACCIÓN</strong>: Hay teoría sin aplicación. El conocimiento se queda en lo abstracto y se olvida pronto.",
            reflexion: "⚠️ <strong>Sin REFLEXIÓN</strong>: Hay experiencia sin aprendizaje. Se hizo mucho, pero no se extrajo el valor pedagógico.",
            evidencia: "⚠️ <strong>Sin EVIDENCIA</strong>: No hay evaluación auténtica. Es imposible verificar si se alcanzaron los objetivos."
        };

        function toggleStep(step) {
            state[step] = !state[step];
            
            const dot = document.getElementById(`dot-${step}`);
            const tglBg = document.getElementById(`toggle-bg-${step}`);
            const card = document.getElementById(`card-${step}`);

            if (state[step]) {
                dot.style.transform = 'translateX(0)';
                tglBg.classList.replace('bg-slate-300', `bg-${getStepColor(step)}-500`);
                card.style.opacity = '1';
                card.style.filter = 'grayscale(0)';
                card.classList.remove('border-dashed', 'border-slate-300');
            } else {
                dot.style.transform = 'translateX(-16px)';
                tglBg.classList.replace(`bg-${getStepColor(step)}-500`, 'bg-slate-300');
                card.style.opacity = '0.4';
                card.style.filter = 'grayscale(1)';
                card.classList.add('border-dashed', 'border-slate-300');
            }

            updateOutcome();
        }

        function getStepColor(step) {
            const colors = { reto: 'indigo', accion: 'emerald', reflexion: 'amber', evidencia: 'blue' };
            return colors[step];
        }

        function resetSim() {
            Object.keys(state).forEach(key => {
                if (!state[key]) toggleStep(key);
            });
        }

        function updateOutcome() {
            const text = document.getElementById('consequence-text');
            const container = document.getElementById('consequence-container');
            
            let missing = [];

            if (!state.reto) missing.push(consequences.reto);
            if (!state.accion) missing.push(consequences.accion);
            if (!state.reflexion) missing.push(consequences.reflexion);
            if (!state.evidencia) missing.push(consequences.evidencia);

            if (missing.length === 0) {
                container.className = "mt-8 p-6 rounded-2xl bg-emerald-50 border border-emerald-200 outcome-box text-center shadow-inner";
                text.innerHTML = "<span class='text-emerald-700 font-bold'><i class='fas fa-check-circle mr-2'></i>Coherencia Pedagógica Total:</span><br><span class='text-emerald-600'>El aprendizaje es auténtico, aplicado y verificable.</span>";
            } else {
                container.className = "mt-8 p-6 rounded-2xl bg-rose-50 border border-rose-200 outcome-box text-left";
                text.innerHTML = `<div class='space-y-3 text-rose-700 text-sm md:text-base'>${missing.join('<br>')}</div>`;
            }
        }

        // Initialize
        updateOutcome();
    </script>
</body>
</html>
